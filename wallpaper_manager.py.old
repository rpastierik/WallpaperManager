#!/usr/bin/env python3
"""
Wallpaper Manager TUI
Manages random wallpaper rotation on GNOME/Wayland
"""

import os
import json
import random
import subprocess
import threading
import time
from pathlib import Path

from textual.app import App, ComposeResult
from textual.containers import Container, Horizontal, Vertical
from textual.widgets import (
    Header, Footer, Static, Button, Label, Input, DirectoryTree
)
from textual.reactive import reactive
from textual.screen import ModalScreen
from textual import on, work
from textual.worker import Worker
from rich.text import Text

CONFIG_FILE = Path.home() / ".config" / "wallpaper-manager" / "config.json"

DEFAULT_CONFIG = {
    "wallpaper_dir": str(Path.home() / "wallpapers"),
    "interval": 300,
}

IMAGE_EXTENSIONS = {".jpg", ".jpeg", ".png", ".webp", ".bmp", ".gif"}


def load_config() -> dict:
    if CONFIG_FILE.exists():
        try:
            return json.loads(CONFIG_FILE.read_text())
        except Exception:
            pass
    return DEFAULT_CONFIG.copy()


def save_config(config: dict):
    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(config, indent=2))


def get_wallpapers(directory: str) -> list[str]:
    try:
        return [
            str(p) for p in Path(directory).rglob("*")
            if p.suffix.lower() in IMAGE_EXTENSIONS and p.is_file()
        ]
    except Exception:
        return []


def set_wallpaper(path: str) -> bool:
    try:
        uri = f"file://{path}"
        subprocess.run(
            ["gsettings", "set", "org.gnome.desktop.background", "picture-uri", uri],
            check=True, capture_output=True
        )
        subprocess.run(
            ["gsettings", "set", "org.gnome.desktop.background", "picture-uri-dark", uri],
            check=True, capture_output=True
        )
        return True
    except Exception:
        return False


def get_current_wallpaper() -> str:
    try:
        result = subprocess.run(
            ["gsettings", "get", "org.gnome.desktop.background", "picture-uri"],
            capture_output=True, text=True, check=True
        )
        uri = result.stdout.strip().strip("'\"")
        if uri.startswith("file://"):
            return uri[7:]
        return uri
    except Exception:
        return ""


def format_interval(seconds: int) -> str:
    if seconds < 60:
        return f"{seconds}s"
    elif seconds < 3600:
        return f"{seconds // 60}m"
    else:
        h = seconds // 3600
        m = (seconds % 3600) // 60
        return f"{h}h {m}m" if m else f"{h}h"


class DirPickerScreen(ModalScreen):
    """Modal screen for picking a directory."""

    CSS = """
    DirPickerScreen {
        align: center middle;
    }
    #dir-picker-container {
        width: 70;
        height: 30;
        border: thick $accent;
        background: $surface;
        padding: 1 2;
    }
    #dir-picker-title {
        text-align: center;
        color: $accent;
        text-style: bold;
        margin-bottom: 1;
    }
    DirectoryTree {
        height: 20;
        border: solid $primary-darken-2;
    }
    #dir-picker-buttons {
        margin-top: 1;
        align: center middle;
    }
    """

    def __init__(self, current_dir: str):
        super().__init__()
        self.current_dir = current_dir

    def compose(self) -> ComposeResult:
        with Container(id="dir-picker-container"):
            yield Label("📁  Vyber adresár s wallpapermi", id="dir-picker-title")
            yield DirectoryTree(str(Path.home()), id="dir-tree")
            with Horizontal(id="dir-picker-buttons"):
                yield Button("✓ Potvrdiť", variant="success", id="confirm-dir")
                yield Button("✗ Zrušiť", variant="error", id="cancel-dir")

    def on_directory_tree_directory_selected(self, event: DirectoryTree.DirectorySelected):
        self.selected_path = str(event.path)

    @on(Button.Pressed, "#confirm-dir")
    def confirm(self):
        path = getattr(self, "selected_path", self.current_dir)
        self.dismiss(path)

    @on(Button.Pressed, "#cancel-dir")
    def cancel(self):
        self.dismiss(None)


class WallpaperManagerApp(App):
    CSS = """
    $bg: #0d1117;
    $surface: #161b22;
    $border: #30363d;
    $accent: #58a6ff;
    $green: #3fb950;
    $yellow: #d29922;
    $red: #f85149;
    $text: #e6edf3;
    $muted: #8b949e;

    Screen {
        background: $bg;
    }

    Header {
        background: $surface;
        color: $accent;
        text-style: bold;
    }

    Footer {
        background: $surface;
        color: $muted;
    }

    #main-layout {
        width: 100%;
        height: 100%;
        padding: 1 2;
    }

    /* ── Status card ── */
    #status-card {
        border: solid $border;
        background: $surface;
        padding: 1 2;
        margin-bottom: 1;
        height: auto;
    }

    #status-title {
        color: $accent;
        text-style: bold;
        margin-bottom: 1;
    }

    #current-wallpaper {
        color: $text;
    }

    #wallpaper-count {
        color: $muted;
    }

    #timer-display {
        color: $green;
        text-style: bold;
    }

    /* ── Controls card ── */
    #controls-card {
        border: solid $border;
        background: $surface;
        padding: 1 2;
        margin-bottom: 1;
        height: auto;
    }

    #controls-title {
        color: $accent;
        text-style: bold;
        margin-bottom: 1;
    }

    #btn-row {
        height: auto;
        margin-bottom: 1;
    }

    Button {
        margin-right: 1;
    }

    #btn-next {
        background: $accent;
        color: $bg;
    }

    #btn-next:hover {
        background: #79c0ff;
    }

    #btn-toggle {
        background: $green;
        color: $bg;
    }

    #btn-toggle.paused {
        background: $yellow;
        color: $bg;
    }

    #btn-toggle:hover {
        opacity: 0.85;
    }

    /* ── Settings card ── */
    #settings-card {
        border: solid $border;
        background: $surface;
        padding: 1 2;
        margin-bottom: 1;
        height: auto;
    }

    #settings-title {
        color: $accent;
        text-style: bold;
        margin-bottom: 1;
    }

    .setting-row {
        height: 3;
        margin-bottom: 1;
        align: left middle;
    }

    .setting-label {
        width: 22;
        color: $muted;
    }

    Input {
        width: 30;
        background: $bg;
        border: solid $border;
        color: $text;
    }

    Input:focus {
        border: solid $accent;
    }

    #btn-apply-dir {
        background: $surface;
        border: solid $border;
        color: $text;
        margin-left: 1;
    }

    #btn-apply-interval {
        background: $surface;
        border: solid $border;
        color: $text;
        margin-left: 1;
    }

    /* ── Log card ── */
    #log-card {
        border: solid $border;
        background: $surface;
        padding: 1 2;
        height: 1fr;
    }

    #log-title {
        color: $accent;
        text-style: bold;
        margin-bottom: 1;
    }

    #log-content {
        color: $muted;
        height: 1fr;
        overflow-y: auto;
    }
    """

    BINDINGS = [
        ("n", "next_wallpaper", "Ďalší"),
        ("space", "toggle_rotation", "Play/Pause"),
        ("q", "quit", "Koniec"),
    ]

    TITLE = "🖼  Wallpaper Manager"

    running: reactive[bool] = reactive(True)
    countdown: reactive[int] = reactive(0)
    current_path: reactive[str] = reactive("")
    wallpaper_count: reactive[int] = reactive(0)

    def __init__(self):
        super().__init__()
        self.config = load_config()
        self.log_lines: list[str] = []
        self._rotation_thread: threading.Thread | None = None
        self._stop_event = threading.Event()
        self._skip_event = threading.Event()

    def compose(self) -> ComposeResult:
        yield Header(show_clock=True)

        with Vertical(id="main-layout"):
            # Status
            with Container(id="status-card"):
                yield Label("◈  Aktuálny stav", id="status-title")
                yield Label("", id="current-wallpaper")
                yield Label("", id="wallpaper-count")
                yield Label("", id="timer-display")

            # Controls
            with Container(id="controls-card"):
                yield Label("◈  Ovládanie", id="controls-title")
                with Horizontal(id="btn-row"):
                    yield Button("⏭  Ďalší wallpaper", id="btn-next")
                    yield Button("⏸  Pozastaviť", id="btn-toggle")

            # Settings
            with Container(id="settings-card"):
                yield Label("◈  Nastavenia", id="settings-title")
                with Horizontal(classes="setting-row"):
                    yield Label("📁 Adresár:", classes="setting-label")
                    yield Input(self.config["wallpaper_dir"], id="input-dir")
                    yield Button("Vybrať", id="btn-apply-dir")
                with Horizontal(classes="setting-row"):
                    yield Label("⏱  Interval (sek):", classes="setting-label")
                    yield Input(str(self.config["interval"]), id="input-interval")
                    yield Button("Použiť", id="btn-apply-interval")

            # Log
            with Container(id="log-card"):
                yield Label("◈  Denník", id="log-title")
                yield Static("", id="log-content")

        yield Footer()

    def on_mount(self):
        self._refresh_wallpapers()
        current = get_current_wallpaper()
        if current:
            self.current_path = current
            self._update_current_label()
        self.countdown = self.config["interval"]
        self._start_rotation()
        self._add_log("✓ Wallpaper manager spustený")

    # ── Rotation logic ──────────────────────────────────────────

    def _start_rotation(self):
        self._stop_event.clear()
        self._rotation_thread = threading.Thread(
            target=self._rotation_loop, daemon=True
        )
        self._rotation_thread.start()

    def _rotation_loop(self):
        while not self._stop_event.is_set():
            interval = self.config["interval"]
            self.countdown = interval
            for remaining in range(interval, 0, -1):
                if self._stop_event.is_set():
                    return
                if self._skip_event.is_set():
                    self._skip_event.clear()
                    break
                self.countdown = remaining
                time.sleep(1)
            else:
                self.call_from_thread(self._pick_and_set)
                continue
            # skip was triggered
            self.call_from_thread(self._pick_and_set)

    def _pick_and_set(self):
        wallpapers = get_wallpapers(self.config["wallpaper_dir"])
        if not wallpapers:
            self._add_log("⚠  Žiadne obrázky nenájdené")
            return
        path = random.choice(wallpapers)
        if set_wallpaper(path):
            self.current_path = path
            self._update_current_label()
            name = Path(path).name
            self._add_log(f"✓ {name}")
        else:
            self._add_log("✗ Nepodarilo sa nastaviť wallpaper")

    # ── UI updates ───────────────────────────────────────────────

    def watch_countdown(self, value: int):
        if self.running:
            label = self.query_one("#timer-display", Static)
            label.update(f"⏱  Ďalšia zmena za: {format_interval(value)}")

    def watch_running(self, value: bool):
        btn = self.query_one("#btn-toggle", Button)
        timer_label = self.query_one("#timer-display", Static)
        if value:
            btn.label = "⏸  Pozastaviť"
            btn.remove_class("paused")
        else:
            btn.label = "▶  Spustiť"
            btn.add_class("paused")
            timer_label.update("⏸  Rotácia pozastavená")

    def _update_current_label(self):
        label = self.query_one("#current-wallpaper", Static)
        if self.current_path:
            name = Path(self.current_path).name
            label.update(f"🖼  {name}")
        else:
            label.update("🖼  —")

    def _refresh_wallpapers(self):
        wallpapers = get_wallpapers(self.config["wallpaper_dir"])
        self.wallpaper_count = len(wallpapers)
        label = self.query_one("#wallpaper-count", Static)
        label.update(f"📂 {self.config['wallpaper_dir']}  ({self.wallpaper_count} obrázkov)")

    def _add_log(self, message: str):
        t = time.strftime("%H:%M:%S")
        self.log_lines.append(f"[{t}] {message}")
        if len(self.log_lines) > 20:
            self.log_lines = self.log_lines[-20:]
        log = self.query_one("#log-content", Static)
        log.update("\n".join(self.log_lines))

    # ── Button handlers ──────────────────────────────────────────

    @on(Button.Pressed, "#btn-next")
    def action_next_wallpaper(self):
        if self.running:
            self._skip_event.set()
        else:
            self._pick_and_set()

    @on(Button.Pressed, "#btn-toggle")
    def action_toggle_rotation(self):
        self.running = not self.running
        if self.running:
            self._stop_event.clear()
            self._start_rotation()
            self._add_log("▶  Rotácia spustená")
        else:
            self._stop_event.set()
            self._add_log("⏸  Rotácia pozastavená")

    @on(Button.Pressed, "#btn-apply-dir")
    def pick_directory(self):
        def on_dismiss(result):
            if result:
                self.query_one("#input-dir", Input).value = result
                self._apply_dir(result)

        self.push_screen(DirPickerScreen(self.config["wallpaper_dir"]), on_dismiss)

    @on(Button.Pressed, "#btn-apply-interval")
    def apply_interval(self):
        val = self.query_one("#input-interval", Input).value
        try:
            seconds = int(val)
            if seconds < 5:
                self._add_log("⚠  Minimálny interval je 5 sekúnd")
                return
            self.config["interval"] = seconds
            save_config(self.config)
            self.countdown = seconds
            self._add_log(f"✓ Interval nastavený na {format_interval(seconds)}")
            if self.running:
                self._stop_event.set()
                time.sleep(0.1)
                self._start_rotation()
        except ValueError:
            self._add_log("✗ Neplatná hodnota intervalu")

    @on(Input.Submitted, "#input-dir")
    def apply_dir_from_input(self, event: Input.Submitted):
        self._apply_dir(event.value)

    @on(Input.Submitted, "#input-interval")
    def apply_interval_from_input(self):
        self.apply_interval()

    def _apply_dir(self, path: str):
        if not Path(path).is_dir():
            self._add_log(f"✗ Adresár neexistuje: {path}")
            return
        self.config["wallpaper_dir"] = path
        save_config(self.config)
        self._refresh_wallpapers()
        self._add_log(f"✓ Adresár: {path}")

    def on_unmount(self):
        self._stop_event.set()


if __name__ == "__main__":
    app = WallpaperManagerApp()
    app.run()
